@startuml sequence_plugin_commands
!include ../../../design/theme.iuml

mainframe **sd** Command Flow with Plugin Hooks & Context

actor Client
    participant "Evaluator" as Evaluator
    participant "Hook Executor" as HookExec
    participant "Hook Registry" as HookReg
    participant "PluginConn\n(multiplexed)" as PluginConn
    participant "Auth Plugin\n(critical, priority=1)" as PluginA
    participant "Metrics Plugin\n(non-critical, priority=100)" as PluginM
    participant "Cache" as Cache

    Client -> Evaluator : SET user:1 {name: John}

    == Initialize Context ==

    Evaluator -> Evaluator : hookCtx = command.NewHookCtx()\nhookCtx["_start_ns"] = now()

    == Pre-Hooks ==

    Evaluator -> HookExec : RunPreHooks("SET", args, hookCtx)
    HookExec -> HookReg : MatchPre("SET")
    HookReg --> HookExec : [Auth(crit, pri=1)]\nsorted by priority

    HookExec -> HookExec : metadata = extractRexMetadata(hookCtx)\n{traceparent: "...", tenant: "..."}

    HookExec -> PluginConn : Send HookRequestV1 (PRE)\ncontext: {_start_ns, shared.rex.*}\nmetadata: {traceparent, tenant}
    PluginConn -> PluginA : HookRequestV1\n(request_id=req-1)
    activate PluginA
    PluginA --> PluginConn : HookResponseV1\n(deny=false,\ncontext_values: {tenant_id: "acme"})
    deactivate PluginA
    PluginConn --> HookExec : Allow

    hnote over HookExec : command.MergeHookCtx(hookCtx, "auth", values)\nhookCtx now has auth.tenant_id

    HookExec --> Evaluator : PreHookResult{Denied=false, Context=hookCtx}

    == Command Execution ==

    Evaluator -> Cache : Engine.DispatchWithResult(fn)
    activate Cache
    Cache --> Evaluator : Result{Value: "OK"}
    deactivate Cache

    Evaluator -> Evaluator : hookCtx["_elapsed_ns"] = elapsed()

    == Post-Hooks ==

    Evaluator -> HookExec : RunPostHooks("SET", args, "OK", "", hookCtx)
    HookExec -> HookReg : MatchPost("SET")

    hnote over HookExec : command.FilterHookCtx(hookCtx, "gobservability")\nreturns: {_start_ns, _elapsed_ns, shared.*}

    HookExec ->> PluginM : HookRequestV1 POST\n(fire-and-forget)\ncontext: {_start_ns, _elapsed_ns, shared.rex.*}\nmetadata: {traceparent, tenant}
    note right : Non-critical: no wait.\nReads _elapsed_ns for latency histogram.\nmetadata has bare keys for easy access.

    == Response ==

    Evaluator --> Client : +OK

@enduml
